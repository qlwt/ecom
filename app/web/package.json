{
    "name": "@fst/app-web",
    "private": true,
    "type": "module",
    "version": "1.0.0",
    "scripts": {
        "serve:dev": "bun ./build/server/entry/index_dev.js",
        "serve:prod": "bun ./build/server/entry/index_prod.js",
        "build": "run-p build:client build:server",
        "build:client": "run-s build:client:public build:client:console",
        "build:client:console": "run-s build:client:console:clean build:client:console:bundle",
        "build:client:console:clean": "rimraf ./build/client/console",
        "build:client:console:bundle": "vite build -c ./script/vite/vite_console.config.js",
        "build:client:public": "run-s build:client:public:clean build:client:public:bundle",
        "build:client:public:clean": "rimraf ./build/client/public",
        "build:client:public:bundle": "vite build -c ./script/vite/vite_public.config.js",
        "build:server": "run-s build:server:clean build:server:bundle",
        "build:server:clean": "rimraf ./build/server",
        "build:server:bundle": "rollup -c ./script/rollup/rollup.config.js"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^28.0.6",
        "@rollup/plugin-image": "^3.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-typescript": "^12.1.4",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.3",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.1.9",
        "@vitejs/plugin-react": "^5.0.2",
        "@fst/rest": "workspace:@fst/rest^1.0.0",
        "@fst/express-utils": "workspace:@fst/express-utils^1.0.0",
        "babel-plugin-react-compiler": "1.0.0",
        "dotenv": "^17.2.2",
        "npm-run-all": "^4.1.5",
        "rimraf": "^6.0.1",
        "rollup": "^4.50.1",
        "sass-embedded": "^1.92.1",
        "typescript": "^5.9.2",
        "vite": "^7.1.5",
        "vite-tsconfig-paths": "^5.1.4"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^6.7.2",
        "@fortawesome/free-brands-svg-icons": "^6.7.2",
        "@fortawesome/free-regular-svg-icons": "^6.7.2",
        "@fortawesome/free-solid-svg-icons": "^6.7.2",
        "@fortawesome/react-fontawesome": "^0.2.2",
        "@fst/config": "workspace:@fst/config^1.0.0",
        "@fst/db-default": "workspace:@fst/db-default^1.0.0",
        "@fst/gstate": "workspace:@fst/gstate^1.0.0",
        "@fst/syntax-math": "workspace:@fst/syntax-math^1.0.0",
        "@fst/syntax-search": "workspace:@fst/syntax-search^1.0.0",
        "@fst/cst": "workspace:@fst/cst^1.0.0",
        "@fst/capi": "workspace:@fst/capi^1.0.0",
        "@qyu/syntax-core": "^1.0.0",
        "@qyu/atom-state-core": "^5.0.1",
        "@qyu/atom-state-react": "^2.0.3",
        "@qyu/reactcmp-dropdown": "^2.2.0",
        "@qyu/reactcmp-flow-control": "^1.2.0",
        "@qyu/reactcmp-modal": "^1.0.2",
        "@qyu/signal-core": "^2.0.0",
        "@qyu/signal-react": "^2.0.0",
        "bezier-easing": "^2.1.0",
        "browser-image-compression": "^2.0.2",
        "classnames": "^2.5.1",
        "compression": "^1.8.1",
        "express": "^5.1.0",
        "i18next": "^25.10.3",
        "i18next-browser-languagedetector": "^8.2.1",
        "imask": "^7.6.1",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-i18next": "^16.6.0",
        "react-imask": "^7.6.1",
        "react-router": "^7.9.1",
        "tslib": "^2.8.1",
        "uuid": "^13.0.0",
        "zod": "^4.1.8"
    }
}
